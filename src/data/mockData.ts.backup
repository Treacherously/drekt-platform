// Helper functions
export const getSupplierById = (id: string): Supplier | undefined => {
  return suppliers.find((supplier) => supplier.id === id);
};

export const getSuppliersByCity = (city: string): Supplier[] => {
  return suppliers.filter((supplier) => supplier.city === city);
};

export const getSuppliersByRole = (role: BusinessRole): Supplier[] => {
  return suppliers.filter((supplier) => supplier.role === role);
};

export const getProducers = (): Supplier[] => {
  return suppliers.filter((supplier) => supplier.role === 'Producer');
};

export const getDistributors = (): Supplier[] => {
  return suppliers.filter((supplier) => supplier.role === 'Distributor');
};

export const getRawSuppliers = (): Supplier[] => {
  return suppliers.filter((supplier) => supplier.role === 'Supplier');
};

export const getProducersByCategory = (category: string): Supplier[] => {
  return suppliers.filter(
    (supplier) => supplier.role === 'Producer' && supplier.productCategory === category
  );
};

export const getDistributorsByType = (type: string): Supplier[] => {
  return suppliers.filter(
    (supplier) => supplier.role === 'Distributor' && supplier.businessType === type
  );
};

export type StockLevel = 'high' | 'medium' | 'low';

// Philippine Supply Chain Roles
export type BusinessRole = 'Producer' | 'Distributor' | 'Supplier';

// Producer Types (Farms, Manufacturers)
export type ProducerType = 'Rice Farm' | 'Corn Farm' | 'Coconut Farm' | 'Mango Farm' | 'Abaca Farm' | 'Vegetable Farm' | 'Fishery' | 'Livestock Farm' | 'Food Manufacturer' | 'Textile Manufacturer';

// Distributor Types
export type DistributorType = 'Supermarket' | 'Wet Market' | 'Drugstore' | 'Department Store' | 'Electronics Store' | 'Textile Market' | 'Hardware Store';

// Supplier Types (Raw materials, Logistics)
export type SupplierType = 'Raw Materials' | 'Logistics' | 'Packaging' | 'Equipment';

export interface Product {
  id: string;
  name: string;
  sku: string;
  stockLevel: StockLevel;
  quantity: number;
  pricePerUnit: number;
  unit: string;
  lastUpdated: string;
}

export interface Supplier {
  id: string;
  name: string;
  city: string;
  role: BusinessRole;
  businessType: ProducerType | DistributorType | SupplierType;
  productCategory: string;
  description: string;
  latitude: number;
  longitude: number;
  products: Product[];
  contactEmail: string;
  contactPhone: string;
}

